[Unit]
Description=VF Ops Watch health runner
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/vector-forge/projects/vf-ops-watch
ExecStart=/usr/bin/python3 /home/ubuntu/vector-forge/projects/vf-ops-watch/runner.py --config /home/ubuntu/vector-forge/projects/vf-ops-watch/config.yaml

# Hardening (safe defaults for local script)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=false
ReadWritePaths=/home/ubuntu/vector-forge/projects/vf-ops-watch/out
